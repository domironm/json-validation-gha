{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["release"],
  "properties": {
    "release": { "type": "string" },
    "override": {
      "type": "object",
      "properties": {
        "rex-release": { "type": "string" },
        "rex-infra": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
  "errorMessage": {
    "additionalProperties": "Invalid key in 'override'. Allowed keys: rex-release, rex-infra"
  },
  "additionalProperties": false
}
